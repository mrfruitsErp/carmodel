###############################################
# CarModel ERP — .env produzione
# Copia su /var/www/carmodel/.env e personalizza
###############################################

APP_NAME="CarModel ERP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://alecar.it
APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_TIMEZONE=Europe/Rome

# ─── Logging ─────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ─── Database (sostituisci con i valori da /root/carmodel-credentials.txt) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=carmodel
DB_USERNAME=carmodel
DB_PASSWORD=METTI_QUI_LA_PASSWORD_GENERATA

# ─── Sessioni / Cache / Queue (file = niente Redis, RAM bassa) ───
BROADCAST_CONNECTION=log
CACHE_STORE=file
CACHE_PREFIX=carmodel
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ─── Mail SMTP (configurabili anche da Impostazioni → Mail) ───
MAIL_MAILER=smtp
MAIL_HOST=smtp.legalmail.it
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@alecar.it"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Sicurezza extra ─────────────────────────────
SANCTUM_STATEFUL_DOMAINS=alecar.it,www.alecar.it
SESSION_DOMAIN=.alecar.it

# ─── AI (opzionale, sovrascrivibile da Settings → AI) ────
AI_API_KEY=
AI_PROVIDER=anthropic
AI_MODEL=claude-3-5-sonnet-20240620

# ─── Spatie Media Library ─────────────────────────
MEDIA_DISK=public
